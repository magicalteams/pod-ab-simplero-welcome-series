# Simplero
SIMPLERO_API_KEY=
SIMPLERO_TAG_ID=               # Numeric ID of the "substack-ready" tag (from GET /tags.json)
SIMPLERO_WEBHOOK_SECRET=       # Random secret appended as ?secret= on the webhook endpoint URL

# Slack (monthly CSV drop)
SLACK_BOT_TOKEN=               # xoxb-... bot token with chat:write + files:write scopes
SLACK_CHANNEL_ID=              # Channel ID (e.g. C0123456789) the bot is invited to

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron (set this in Vercel env, send as Authorization: Bearer <value>)
CRON_SECRET=

# Backfill script — optional, auto-triggers the export cron after seeding the queue
EXPORT_TRIGGER_URL=            # e.g. https://<project>.vercel.app/api/cron/export-substack
